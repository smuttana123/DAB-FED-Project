# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# Pre-Production Environment
PRE_PROD_DATABRICKS_HOST=https://adb-1234567890123456.7.azuredatabricks.net
PRE_PROD_DATABRICKS_TOKEN=your_pre_prod_token_here

# Production Environment
PROD_DATABRICKS_HOST=https://adb-9876543210987654.7.azuredatabricks.net
PROD_DATABRICKS_TOKEN=your_prod_token_here

# Catalog and Schema Configuration
CATALOG=main
BRONZE_SCHEMA=bronze
SILVER_SCHEMA=silver
GOLD_SCHEMA=gold

# Data Source Paths
SOURCE_DATA_PATH_CUSTOMERS=s3://your-bucket/raw-data/customers/
SOURCE_DATA_PATH_ORDERS=s3://your-bucket/raw-data/orders/

# Email Notifications
JOB_NOTIFICATION_EMAIL=your.email@company.com

# Databricks Cluster Configuration
NODE_TYPE_ID=Standard_DS3_v2  # Azure example, use i3.xlarge for AWS
